# ============================================================
# Supabase  (Project Settings -> API)
# ============================================================
# Copie este arquivo para .env.local e preencha com seus valores.
# NÃO coloque chaves reais aqui — este arquivo vai para o Git.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# "anon / public" key  (safe to expose, used for auth/login)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
# "service_role" key  (SECRET - server only, never expose)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ============================================================
# App
# ============================================================
# URL pública onde o app está rodando (usada pelo tracker como endpoint).
# Local: http://localhost:3000   Prod: https://seu-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
